# Local-only settings example.
# Copy this to .env only for local experiments.
# Do not commit real secrets or API keys.

PORT=3000
NODE_ENV=development

# AI is disabled by default.
AI_ENABLED=false
AI_PROVIDER=openrouter

# Free smoke test model. Free model availability and rate limits may change.
AI_MODEL=meta-llama/llama-3.2-3b-instruct:free

# Cheap paid fallback for debugging free-model 429.
# This will consume OpenRouter credits. Confirm credit limits before use.
# AI_MODEL=qwen/qwen-2.5-7b-instruct

AI_BASE_URL=https://openrouter.ai/api/v1
AI_API_KEY=
AI_MAX_OUTPUT_TOKENS=800
AI_TEMPERATURE=0.7

# Gemini OpenAI-compatible remains available as an alternate provider.
# AI_PROVIDER=gemini-openai-compatible
# AI_MODEL=gemini-3.5-flash
# AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# Do not put real keys in this example file.
# Real API keys must only be stored in a local .env file or deployment platform secret.
# Never commit .env, API keys, tokens, or secrets.
